# Подставляется в docker compose при сборке web: NEXT_PUBLIC_API_URL.
# Относительный путь — в браузере запросы идут на тот же хост, что и страница (Nginx → api), без CORS.
# Не задавайте полный URL с IP (http://89.../api), если сайт открывают по домену.
NEXT_PUBLIC_API_URL=/api

# Яндекс.Метрика — номер счётчика (при сборке web: docker compose --env-file docker.env build)
# NEXT_PUBLIC_YM_ID=108316679
