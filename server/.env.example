PORT=4000
# Точный origin фронта в браузере (схема + хост + порт, без слэша в конце) — совпадает с CORS.
# Локально: http://localhost:3000. На VPS по домену: http://ваш-домен.ru или https://ваш-домен.ru
# Не указывайте IP сервера, если сайт открывают по домену — иначе CORS-ошибки.
FRONTEND_URL=http://localhost:3000
JWT_SECRET=замените-на-свой-секрет-минимум-32-символа
# Локально: файл в корне server/. В Docker Compose задаётся в docker-compose (file:./data/autoparts.db + том).
DATABASE_URL="file:./autoparts.db"

# ── Парсинг сайтов поставщиков (Playwright) ──
SUPPLIER_TIMEOUT_MS=15000
CACHE_TTL_MINUTES=30

# Rossko (парсинг ussuri.rossko.ru)
ROSSKO_URL=https://ussuri.rossko.ru

# MX Group (парсинг mxgroup.ru)
MXGROUP_URL=https://mxgroup.ru

# AutoTrade (SPA, парсинг autotrade.su)
AUTOTRADE_URL=https://autotrade.su/vladivostok

# TISS (требуется авторизация на my.tiss.ru)
TISS_URL=https://my.tiss.ru
TISS_LOGIN=ваш-логин
TISS_PASSWORD=ваш-пароль

# AutoBiz (парсинг autobiz.ru)
AUTOBIZ_URL=https://autobiz.ru

# AM25 (SPA, парсинг am25.ru)
AM25_URL=https://am25.ru

# TrustAuto (поиск временно недоступен на trustautovl.ru)
TRUSTAUTO_URL=https://trustautovl.ru

# ── Email-уведомления через Gmail SMTP (Nodemailer) ──
# SMTP_USER — ваш Gmail-адрес
# SMTP_PASS — «Пароль приложения» (НЕ обычный пароль от Gmail!)
#   Создать: Google Аккаунт → Безопасность → Двухэтапная аутентификация → Пароли приложений
SMTP_USER=your-email@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
SMTP_SENDER_NAME=AutoPartsDV
