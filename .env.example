# Скопируйте в `.env` в корне репозитория, если нужно переопределить переменные для `docker compose build`.
# Docker Compose подхватывает файл `.env` автоматически (рядом с docker-compose.yml).

# Сборка образа web: вшивается в клиентский JS. Для одного домена за Nginx оставьте /api.
# Не указывайте http://IP/... — иначе при открытии сайта по домену будет ошибка CORS.
NEXT_PUBLIC_API_URL=/api

# Яндекс.Метрика (вшивается при docker compose build web). Локально: .env.local
# NEXT_PUBLIC_YM_ID=108316679

# --- Nginx (только на VPS с HTTPS, файл .env в корне репозитория) ---
# Не копируйте nginx-конфиг вручную: укажите файл с listen 443 и ssl_certificate:
# NGINX_CONF=./deploy/nginx.autopartsdv.space.conf
# По умолчанию без этой строки используется deploy/nginx.http.conf (только порт 80).
