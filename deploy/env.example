# Скопируйте в корень репозитория как файл `.env` — Docker Compose подставит при сборке образа `web`.
# Замените на реальный адрес, с которого пользователи открывают сайт (тот же хост, что у Nginx).
#
# Пример с доменом:
# NEXT_PUBLIC_API_URL=https://autoparts.example.ru/api
#
# Пример только по IP (порт 80):
# NEXT_PUBLIC_API_URL=http://203.0.113.10/api

NEXT_PUBLIC_API_URL=http://localhost/api
